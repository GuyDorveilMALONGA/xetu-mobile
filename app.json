{
  "expo": {
    "name": "Xetu",
    "slug": "xetu-mobile",
    "version": "1.0.0",
    "scheme": "xetu",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.xetu.mobile",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Autoriser Xetu à utiliser votre position pour afficher les arrêts proches et partager un signalement quand vous le demandez."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Autoriser Xetu à utiliser votre position pour partager votre position de bus quand vous le demandez."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "cdbb9783-733f-421b-a6d9-0305e41a76d5"
      }
    },
    "owner": "dorveil"
  }
}
